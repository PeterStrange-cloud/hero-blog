@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    --font-display: Fraunces;
    --font-body: SpaceGrotesk;
    --font-mono: GeistMono;
    --radius: 0.375rem;
    --background: 0.08 0 0;
    --foreground: 0.96 0 0;
    --card: 0.12 0 0;
    --card-foreground: 0.96 0 0;
    --popover: 0.14 0 0;
    --popover-foreground: 0.96 0 0;
    --primary: 0.65 0.25 25;
    --primary-foreground: 0.98 0 0;
    --secondary: 0.18 0 0;
    --secondary-foreground: 0.88 0 0;
    --muted: 0.18 0 0;
    --muted-foreground: 0.6 0 0;
    --accent: 0.75 0.2 145;
    --accent-foreground: 0.08 0 0;
    --destructive: 0.65 0.25 25;
    --destructive-foreground: 0.98 0 0;
    --border: 0.22 0.02 25;
    --input: 0.18 0 0;
    --ring: 0.65 0.25 25;
    --chart-1: 0.65 0.25 25;
    --chart-2: 0.75 0.2 145;
    --chart-3: 0.6 0.12 185;
    --chart-4: 0.83 0.19 84;
    --chart-5: 0.77 0.19 70;
    --sidebar: 0.12 0 0;
    --sidebar-foreground: 0.96 0 0;
    --sidebar-primary: 0.65 0.25 25;
    --sidebar-primary-foreground: 0.98 0 0;
    --sidebar-accent: 0.18 0 0;
    --sidebar-accent-foreground: 0.88 0 0;
    --sidebar-border: 0.22 0.02 25;
    --sidebar-ring: 0.65 0.25 25;
  }

  .dark {
    color-scheme: dark;
    --background: 0.12 0 0;
    --foreground: 0.96 0 0;
    --card: 0.16 0 0;
    --card-foreground: 0.96 0 0;
    --popover: 0.2 0 0;
    --popover-foreground: 0.96 0 0;

    --primary: 0.64 0.18 45;
    --primary-foreground: 0.12 0 0;

    --secondary: 0.2 0 0;
    --secondary-foreground: 0.88 0 0;
    --muted: 0.24 0 0;
    --muted-foreground: 0.58 0 0;

    --accent: 0.64 0.18 45;
    --accent-foreground: 0.12 0 0;

    --destructive: 0.65 0.19 22;
    --destructive-foreground: 0.96 0 0;

    --border: 0.22 0 0;
    --input: 0.22 0 0;
    --ring: 0.64 0.18 45;

    --chart-1: 0.49 0.24 264;
    --chart-2: 0.7 0.17 162;
    --chart-3: 0.77 0.19 70;
    --chart-4: 0.63 0.27 304;
    --chart-5: 0.65 0.25 16;

    --sidebar: 0.16 0 0;
    --sidebar-foreground: 0.96 0 0;
    --sidebar-primary: 0.64 0.18 45;
    --sidebar-primary-foreground: 0.12 0 0;
    --sidebar-accent: 0.2 0 0;
    --sidebar-accent-foreground: 0.88 0 0;
    --sidebar-border: 0.22 0 0;
    --sidebar-ring: 0.64 0.18 45;
  }

  * {
    @apply border-border;
  }
  body {
    @apply bg-background text-foreground font-body antialiased;
  }
}

@layer utilities {
  .transition-smooth {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .type-display {
    @apply font-display text-4xl font-bold tracking-tight;
  }

  .type-headline {
    @apply font-display text-2xl font-bold;
  }

  .type-subheadline {
    @apply font-body text-lg font-semibold;
  }

  .type-body-lg {
    @apply font-body text-base font-normal leading-relaxed;
  }

  .type-body {
    @apply font-body text-sm font-normal;
  }

  .type-label {
    @apply font-body text-xs font-semibold uppercase tracking-wide;
  }

  .type-meta {
    @apply font-body text-xs text-muted-foreground;
  }
}

@font-face {
  font-family: "Fraunces";
  src: url("/assets/fonts/Fraunces.woff2") format("woff2");
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}

@font-face {
  font-family: "SpaceGrotesk";
  src: url("/assets/fonts/SpaceGrotesk.woff2") format("woff2");
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}

@font-face {
  font-family: "GeistMono";
  src: url("/assets/fonts/GeistMono.woff2") format("woff2");
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}




@layer base {
  body {
    background: oklch(0.08 0 0);
    background-image:
      radial-gradient(ellipse 60% 50% at 50% 0%, oklch(0.45 0.25 25 / 0.35), transparent 70%),
      radial-gradient(ellipse 40% 30% at 80% 100%, oklch(0.55 0.18 145 / 0.12), transparent 70%);
    background-attachment: fixed;
    min-height: 100vh;
  }
}

@layer utilities {
  .glow-red {
    box-shadow: 0 0 24px -4px oklch(0.65 0.25 25 / 0.35);
    border-color: oklch(0.65 0.25 25 / 0.4);
  }
  .glow-green {
    box-shadow: 0 0 24px -4px oklch(0.75 0.2 145 / 0.35);
    border-color: oklch(0.75 0.2 145 / 0.4);
  }
  .text-hero-red {
    color: oklch(0.65 0.25 25);
  }
  .text-hero-green {
    color: oklch(0.75 0.2 145);
  }
}


@layer components {
  /* Punchy primary button — red with subtle glow */
  button.bg-primary,
  .bg-primary {
    box-shadow: 0 0 20px -6px oklch(0.65 0.25 25 / 0.5);
  }
  button.bg-primary:hover,
  .bg-primary:hover {
    box-shadow: 0 0 28px -4px oklch(0.65 0.25 25 / 0.7);
  }
}
